{
  "name": "creator-portfolio",
  "private": true,
  "version": "1.3.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/404.html')\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "vite --host & sleep 1 && open http://localhost:5173/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "bump-version": "npm version patch -m \"release: bump patch to %s\" && git push --follow-tags",
    "pc-sync-main": "pwsh ./scripts/sync-main.ps1",
    "reset-history": "powershell -Command \"Remove-Item (Get-PSReadLineOption).HistorySavePath; echo 'history was reset'\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "firebase": "^12.11.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.1"
  }
}
